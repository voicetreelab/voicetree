{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/webapp/.claude/hooks/file-size-check.cjs\"",
            "timeout": 30,
            "statusMessage": "Checking edited file sizes"
          }
        ]
      }
    ]
  }
}
