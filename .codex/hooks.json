{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/run-per-edit.cjs\"",
            "timeout": 30,
            "statusMessage": "Running per-edit measures"
          }
        ]
      }
    ]
  }
}
