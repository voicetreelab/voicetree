#!/bin/bash
# Route to the dev box when VT_REMOTE_HOST is set (mirrors `npm run test`),
# else run locally. The actual pipeline lives in pre-push.run.sh →
# pre-push.impl.sh. Bypass with `git push --no-verify`.
set -e
exec node --no-warnings=ExperimentalWarning --experimental-strip-types \
  scripts/run-remote.mjs \
  bash scripts/hooks/pre-push.run.sh "$@"
