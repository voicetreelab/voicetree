#!/bin/bash
# Pre-commit gate. Two hard checks, in order:
#   1. tier-0 static checks (typecheck/lint/etc) via npm run test:t0
#   2. subgraph-scoped codebase-health gate via npm run health:subgraph-gate
# Both route through scripts/run-remote.mjs (via the bin/npm shim). When
# VT_REMOTE_HOST is set, they execute on the devbox — the local .git/index is
# mutagen-synced (see scripts/dev-setup/remote/mutagen-vt-remote.yml) so the
# devbox sees the same staged tree as local git.
set -e
repo_root="$(git rev-parse --show-toplevel)"
export PATH="$repo_root/bin:$PATH"

merge_conflict_files() {
    merge_msg="$(git rev-parse --git-path MERGE_MSG)"
    [ -f "$merge_msg" ] || return 0
    awk '
        /^# Conflicts:/ || /^Conflicts:/ {in_conflicts = 1; next}
        in_conflicts {
            line = $0
            sub(/^#[[:space:]]*/, "", line)
            sub(/^[[:space:]]+/, "", line)
            if (line == "") next
            print line
        }
    ' "$merge_msg"
}

is_merge_commit() {
    git rev-parse -q --verify MERGE_HEAD >/dev/null
}

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
if printf '%s\n' "$staged_files" | grep -qE '^(packages/measures/src/checks/.*\.ts|packages/measures/scripts/gen-workflows\.ts|packages/measures/src/checks/_workflow-types\.ts)$'; then
    npm run gen:workflows
    if ! git diff --quiet -- .github/workflows/measures-budget-gate.yml; then
        echo "measures-budget-gate.yml regenerated — stage it and retry:"
        echo "  git add .github/workflows/measures-budget-gate.yml"
        exit 1
    fi
fi

npm run test:t0

# Subgraph health gate. For merge commits, only conflict resolutions are
# authored in this commit. Upstream TS/TSX changes carried by the merge were
# already gated on their source branch, so do not re-score them just because
# this branch caught up.
subgraph_files="$staged_files"
if is_merge_commit; then
    subgraph_files="$(merge_conflict_files)"
fi

# Skip cheaply if no authored TS/TSX path is staged — those commits have
# nothing for the AST-based measures to score.
if printf '%s\n' "$subgraph_files" | grep -qE '\.(ts|tsx)$'; then
    npm run health:subgraph-gate
fi
