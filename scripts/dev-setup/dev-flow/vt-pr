#!/usr/bin/env bash
# vt-pr — the reviewed path (D8). Commit (optional), push the feature branch,
# and open a PR against the integration branch via gh. Slower on purpose (CI +
# review); use vt-land for quick solo changes.
#
# The branch push is --no-verify: the gate for reviewed work is the PR's CI
# (measures-budget-gate runs on pull_request), not the local tier<=1 pre-push
# hook. That hook ships the worktree to the VM via run-remote and cannot work
# for a Mac-authored worktree anyway (mutagen reverts the worktree's `.git`
# pointer on the VM), so bypassing it is what makes vt-pr work from a Mac
# worktree. CI still gates the merge.
#
# Usage:
#   vt-pr ["message"]               # PR against the worktree's upstream (else dev-manu)
#   vt-pr --onto <branch> ["msg"]   # PR against an explicit base branch
set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
  _t="$(readlink "$_self")"
  case "$_t" in /*) _self="$_t" ;; *) _self="$(cd "$(dirname "$_self")" && pwd)/$_t" ;; esac
done
_DIR="$(cd "$(dirname "$_self")" && pwd)"
# shellcheck source=_common.sh
. "$_DIR/_common.sh"

onto=""
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    --onto|--base) onto="${2:-}"; shift 2 ;;
    --onto=*)      onto="${1#--onto=}"; shift ;;
    --base=*)      onto="${1#--base=}"; shift ;;
    -h|--help)     sed -n '2,/^set -euo/p' "$_self" | sed 's/^# \{0,1\}//;/^set -euo/d'; exit 0 ;;
    *)             positional+=("$1"); shift ;;
  esac
done
msg="${positional[0]:-}"

require_worktree
[ -n "$onto" ] || onto="$(default_onto)"
branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "$onto" ]; then
  echo "vt-pr: HEAD is on '$onto' (the base of the PR) — create the worktree on a feature branch instead" >&2
  exit 1
fi

# Stage EVERYTHING (git add -A) — tracked edits AND brand-new files — so a PR
# that introduces a new file does the obvious thing. (`git commit -am` staged
# only tracked edits, silently dropping new files — the same footgun vt-land
# already fixed.) git-ignored files are excluded by git add -A.
if [ -n "$(git status --porcelain)" ] && [ -n "$msg" ]; then
  git add -A
  # --no-verify: the pre-commit hook routes to the VM via run-remote (broken for
  # a Mac-authored worktree); CI on the PR is the real gate. See the header note.
  git commit --no-verify -m "$msg"
elif [ -n "$(git status --porcelain)" ]; then
  echo "vt-pr: uncommitted changes present — commit them first, or pass a message: vt-pr \"msg\"" >&2
  exit 1
fi

echo "vt-pr: pushing $branch to origin (--no-verify; CI gates the PR/merge)"
git push --no-verify -u origin "$branch"

if ! command -v gh >/dev/null 2>&1; then
  echo "vt-pr: pushed '$branch'. gh CLI not found — open the PR manually against '$onto'." >&2
  exit 0
fi
gh pr create --base "$onto" --head "$branch" --fill
