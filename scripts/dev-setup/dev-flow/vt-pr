#!/usr/bin/env bash
# vt-pr — commit (optional), push the current branch, and open a PR against the
# shared integration branch (`dev`) via gh. This is how work integrates in the
# per-machine-branch model: you push your branch and open a PR to dev.
#
# The push is --no-verify: the gate for reviewed work is the PR's CI
# (measures-budget-gate runs on pull_request), not the local pre-push tier hook
# (which ships the tree to the VM via run-remote and is unreliable from a synced
# worktree). CI still gates the merge.
#
# Usage:
#   vt-pr ["message"]               # PR the current branch against dev
#   vt-pr --onto <branch> ["msg"]   # PR against an explicit base branch
set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
  _t="$(readlink "$_self")"
  case "$_t" in /*) _self="$_t" ;; *) _self="$(cd "$(dirname "$_self")" && pwd)/$_t" ;; esac
done
_DIR="$(cd "$(dirname "$_self")" && pwd)"
# shellcheck source=_common.sh
. "$_DIR/_common.sh"

onto=""
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    --onto|--base) onto="${2:-}"; shift 2 ;;
    --onto=*)      onto="${1#--onto=}"; shift ;;
    --base=*)      onto="${1#--base=}"; shift ;;
    -h|--help)     sed -n '2,/^set -euo/p' "$_self" | sed 's/^# \{0,1\}//;/^set -euo/d'; exit 0 ;;
    *)             positional+=("$1"); shift ;;
  esac
done
msg="${positional[0]:-}"

git rev-parse --git-dir >/dev/null 2>&1 || { echo "vt-pr: not inside a git repository" >&2; exit 1; }
[ -n "$onto" ] || onto="$(integration_branch)"
branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "$onto" ]; then
  echo "vt-pr: HEAD is on '$onto' (the base of the PR) — switch to a feature branch first (git switch -c <name>)" >&2
  exit 1
fi

# Stage EVERYTHING (git add -A) — tracked edits AND brand-new files — so a PR
# that introduces a new file does the obvious thing. git-ignored files are
# excluded by git add -A.
if [ -n "$(git status --porcelain)" ] && [ -n "$msg" ]; then
  git add -A
  git commit --no-verify -m "$msg"
elif [ -n "$(git status --porcelain)" ]; then
  echo "vt-pr: uncommitted changes present — commit them first, or pass a message: vt-pr \"msg\"" >&2
  exit 1
fi

echo "vt-pr: pushing $branch to origin (--no-verify; CI gates the PR/merge)"
git push --no-verify -u origin "$branch"

if ! command -v gh >/dev/null 2>&1; then
  echo "vt-pr: pushed '$branch'. gh CLI not found — open the PR manually against '$onto'." >&2
  exit 0
fi
gh pr create --base "$onto" --head "$branch" --fill
