#!/usr/bin/env bash
# vt-worktree — thin sugar over `git worktree add`. By hand the same thing is:
#     git -C <base> fetch origin <branch>
#     git -C <base> worktree add -b <name> <name> origin/<branch>
#
# This script does ONLY the two things git-gate's `worktree add` interception
# does NOT: (1) work from ANY cwd by resolving the base checkout (you do not live
# in the base), and (2) fetch origin first so you branch off the latest. It
# passes a BARE name and lets git-gate do PLACEMENT, nesting-prevention, and the
# dependency install — "ALL placement lives in the machine-level git wrapper"
# (distributed-architecture.md). It deliberately does not duplicate any of that;
# the final path is read back from git, never assumed.
#
# Usage:
#   vt-worktree <name> [<branch>]    # branch defaults to dev-manu (VT_BASE_BRANCH)
set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
  _t="$(readlink "$_self")"
  case "$_t" in /*) _self="$_t" ;; *) _self="$(cd "$(dirname "$_self")" && pwd)/$_t" ;; esac
done
_DIR="$(cd "$(dirname "$_self")" && pwd)"
# shellcheck source=_common.sh
. "$_DIR/_common.sh"

name="${1:-}"
branch="${2:-${VT_BASE_BRANCH:-dev-manu}}"
if [ -z "$name" ] || [ "$name" = "-h" ] || [ "$name" = "--help" ]; then
  echo "usage: vt-worktree <name> [<branch>]   (branch defaults to ${VT_BASE_BRANCH:-dev-manu})" >&2
  [ -z "$name" ] && exit 64 || exit 0
fi

# Resolve the base checkout; never depend on the caller's cwd being a repo.
base="${VT_BASE_DIR:-$(self_repo)}"
[ -d "$base/.git" ] || {
  echo "vt-worktree: base '$base' is not a git repository." >&2
  echo "  Set VT_BASE_DIR to your base checkout (the read-only cache of origin)." >&2
  exit 1
}

# Refresh origin so we branch off the latest (the base may be mid-tick).
git -C "$base" fetch origin "$branch" >/dev/null 2>&1 || git -C "$base" fetch origin >/dev/null 2>&1 || true

# Bare name → git-gate rewrites it to this machine's worktree root and installs
# deps. (Without git-gate there is no read-only base, so this never runs un-gated.)
git -C "$base" worktree add -b "$name" "$name" "origin/$branch"

# Read the placed path back from git (truthful — placement is git-gate's, not ours).
dest="$(git -C "$base" worktree list --porcelain \
  | awk -v b="refs/heads/$name" '$1=="worktree"{p=$2} $1=="branch" && $2==b {print p; exit}')"

echo ""
echo "vt-worktree: created '$name' off origin/$branch"
echo "  cd ${dest:-<path printed by git-gate above>}     # edit + run there; then: vt-land \"msg\"  (or vt-pr)"
