#!/usr/bin/env node
/**
 * PATH-shim wrapping `vt`. Prepended to PATH during a bootcamp run so every
 * agent invocation of `vt` flows through here. Writes one JSON file per call
 * into $VT_SHIM_LOG_DIR (atomic by construction — each call has its own file
 * with a unique name, so concurrent vt invocations cannot interleave).
 *
 * Required env:
 *   VT_SHIM_LOG_DIR  — directory to write per-call .json files into (must exist)
 *   VT_REAL_BIN      — absolute path to the real `vt` script
 *
 * Exit code is the real `vt`'s exit code. stderr is captured into the log
 * AND mirrored to the shim's stderr so the agent still sees it.
 *
 * Single Node process per call — replaces an earlier bash shim that cold-started
 * `node -e` three times per call (~150–600ms overhead). This version: ~80ms.
 */
import {spawn} from 'node:child_process'
import * as fs from 'node:fs'
import * as path from 'node:path'

const shimLogDir = process.env.VT_SHIM_LOG_DIR
const realVtBin = process.env.VT_REAL_BIN

if (!shimLogDir) {
    process.stderr.write('vt-shim: VT_SHIM_LOG_DIR must be set\n')
    process.exit(2)
}
if (!realVtBin) {
    process.stderr.write('vt-shim: VT_REAL_BIN must be set\n')
    process.exit(2)
}

const argv = process.argv.slice(2)
const startMs = Date.now()

const child = spawn(realVtBin, argv, {
    stdio: ['inherit', 'inherit', 'pipe'],
})

let stderrCapture = ''
child.stderr.on('data', (chunk) => {
    stderrCapture += chunk.toString('utf8')
    process.stderr.write(chunk)
})

for (const sig of ['SIGINT', 'SIGTERM', 'SIGHUP']) {
    process.on(sig, () => child.kill(sig))
}

child.on('error', (err) => {
    process.stderr.write(`vt-shim: failed to spawn ${realVtBin}: ${err.message}\n`)
    process.exit(127)
})

child.on('close', (code, signal) => {
    const endMs = Date.now()
    const exitCode = code ?? (signal ? 128 : 1)
    const entry = {
        timestampMs: startMs,
        argv,
        cwd: process.cwd(),
        exitCode,
        stderr: stderrCapture,
        durationMs: endMs - startMs,
    }
    const filename = `${startMs.toString().padStart(13, '0')}-${process.pid}-${randomSuffix()}.json`
    fs.writeFileSync(path.join(shimLogDir, filename), JSON.stringify(entry) + '\n')
    process.exit(exitCode)
})

function randomSuffix() {
    return Math.random().toString(36).slice(2, 8)
}
