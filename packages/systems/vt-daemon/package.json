{
  "name": "@vt/vt-daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Voicetree tool catalog + HTTP JSON-RPC daemon server with bearer auth and WebSocket subscription channel. Also ships the standalone vtd binary — a per-vault per-machine daemon that talks to vt-graphd over RPC as a sibling process.",
  "main": "src/agents/index.ts",
  "bin": {
    "vtd": "bin/vtd.ts"
  },
  "exports": {
    ".": "./src/agents/index.ts",
    "./tools/*": "./src/tools/*",
    "./util/findAvailablePort": "./src/tools/findAvailablePort.ts",
    "./util/*": "./src/util/*",
    "./agents/*": "./src/agents/*",
    "./mcp-config": "./src/config/mcp-config-public.ts",
    "./transport/eventTypes": "./src/transport/eventTypes.ts",
    "./bin/vtd.ts": "./bin/vtd.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mermaid-js/parser": "^0.6.2",
    "@vt/agent-runtime": "*",
    "@vt/app-config": "*",
    "@vt/daemon-lifecycle": "*",
    "@vt/graph-db-client": "*",
    "@vt/graph-db-protocol": "*",
    "@vt/graph-model": "*",
    "@vt/graph-state": "*",
    "@vt/graph-tools": "*",
    "@vt/graph-validation": "*",
    "@vt/observability": "*",
    "@vt/vt-daemon-protocol": "*",
    "@vt/vt-rpc": "*",
    "chokidar": "^3.6.0",
    "express": "^4.21.2",
    "fp-ts": "^2.16.9",
    "normalize-path": "^3.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
