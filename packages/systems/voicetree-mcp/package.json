{
  "name": "@vt/voicetree-mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Voicetree tool catalog + UDS JSON-RPC server. Hosts the per-vault catalog (spawn_agent, create_graph, list_agents, …) over a Unix domain socket. Embedded in Electron and consumed by the vt-mcpd headless binary.",
  "main": "src/agents/index.ts",
  "bin": {
    "vt-mcpd": "bin/vt-mcpd.ts"
  },
  "exports": {
    ".": "./src/agents/index.ts",
    "./tools/*": "./src/tools/*",
    "./util/findAvailablePort": "./src/tools/findAvailablePort.ts",
    "./util/*": "./src/util/*",
    "./mcp-config": "./src/config/mcp-config-public.ts",
    "./mcp-client-config": "./src/config/mcp-client-config-public.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mermaid-js/parser": "^0.6.2",
    "@vt/agent-runtime": "*",
    "@vt/app-config": "*",
    "@vt/graph-db-protocol": "*",
    "@vt/graph-db-server": "*",
    "@vt/graph-model": "*",
    "@vt/graph-state": "*",
    "@vt/graph-tools": "*",
    "express": "^4.21.2",
    "fp-ts": "^2.16.9",
    "normalize-path": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
