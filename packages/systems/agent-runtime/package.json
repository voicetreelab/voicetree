{
  "name": "@vt/agent-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Headless agent + terminal runtime: PTY orchestration, terminal registry, headless agent manager, hook dispatch, node injection. Embedded in Electron and consumed by vt-mcpd.",
  "main": "src/api/index.ts",
  "exports": {
    ".": "./src/api/index.ts",
    "./runtime/agent-runtime-api": "./src/api/agent-runtime-api.ts",
    "./api/*": "./src/api/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vt/app-config": "*",
    "@vt/graph-db-protocol": "*",
    "@vt/graph-db-server": "*",
    "@vt/graph-model": "*",
    "@vt/vt-daemon": "*",
    "@vt/vt-daemon-protocol": "*",
    "fp-ts": "^2.16.9",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
