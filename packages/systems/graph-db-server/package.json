{
  "name": "@vt/graph-db-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Headless daemon (vt-graphd) that owns canonical vault state for one vault: sqlite, watch-folder, disk I/O, state stores, CRUD routes.",
  "main": "src/daemon/index.ts",
  "exports": {
    ".": "./src/daemon/index.ts",
    "./package.json": "./package.json",
    "./application/core/*": "./src/application/core/*.ts",
    "./application/workflows/vault": "./src/application/workflows/vault/vault.ts",
    "./application/workflows/vault/*": "./src/application/workflows/vault/*.ts",
    "./application/workflows/*": "./src/application/workflows/*.ts",
    "./application/workflows/watch-folder/*": "./src/application/workflows/watch-folder/*.ts",
    "./application/errors/*": "./src/application/errors/*.ts",
    "./application/session/*": "./src/application/session/*.ts",
    "./contract": "./src/contract.ts",
    "./daemonRouteParity": "./src/routes/daemonRouteParity.ts",
    "./portFile": "./src/daemon/portFile.ts",
    "./views/*": "./src/data/views/*.ts",
    "./graph/applyGraphDelta": "./src/data/graph/mutations/applyGraphDelta.ts",
    "./graph/daemonWatcher": "./src/data/graph/watching/daemonWatcher.ts",
    "./graph/fileLimitEnforce": "./src/data/graph/loading/fileLimitEnforce.ts",
    "./graph/findFileByName": "./src/data/graph/loading/findFileByName.ts",
    "./graph/folderScanner": "./src/data/graph/loading/folderScanner.ts",
    "./graph/graphActionsToDBEffects": "./src/data/graph/mutations/graphActionsToDBEffects.ts",
    "./graph/handleFSEvent": "./src/data/graph/watching/handleFSEvent.ts",
    "./graph/loadAndMergeVaultPath": "./src/data/graph/loading/loadAndMergeVaultPath.ts",
    "./graph/loadGraphFromDisk": "./src/data/graph/loading/loadGraphFromDisk.ts",
    "./graph/notifyTextToTreeServer": "./src/data/graph/loading/notifyTextToTreeServer.ts",
    "./graph/undoOperations": "./src/data/graph/mutations/undoOperations.ts",
    "./graph/writeMarkdownFile": "./src/data/graph/mutations/writeMarkdownFile.ts",
    "./graph/writeAllPositionsOnExit": "./src/data/graph/mutations/writeAllPositionsOnExit.ts",
    "./state/*": "./src/state/*.ts",
    "./watch-folder/watchFolder": "./src/application/workflows/watch-folder/watchFolder.ts",
    "./watch-folder/vault-allowlist": "./src/state/vaultAllowlist.ts",
    "./watch-folder/resolve-vault-config": "./src/data/watch-folder/paths/resolve-vault-config.ts",
    "./watch-folder/*": "./src/data/watch-folder/*.ts",
    "./context-nodes/*": "./src/data/context-nodes/*.ts",
    "./search/*": "./src/search/*.ts",
    "./server": "./src/daemon/server.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx bin/vt-graphd.ts",
    "build": "node build.mjs"
  },
  "bin": {
    "vt-graphd": "bin/vt-graphd.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@opentelemetry/api": "^1.9.1",
    "@vscode/ripgrep": "^1.15.9",
    "@vt/app-config": "*",
    "@vt/daemon-lifecycle": "*",
    "@vt/graph-db-protocol": "*",
    "@vt/graph-model": "*",
    "@vt/graph-state": "*",
    "@vt/graph-tools": "*",
    "@vt/observability": "*",
    "@vt/perf-analysis": "*",
    "chokidar": "^3.6.0",
    "fp-ts": "^2.16.9",
    "hono": "^4.12.12",
    "normalize-path": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/normalize-path": "^3.0.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
