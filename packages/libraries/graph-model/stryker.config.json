{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "mutate": [
    "src/pure/**/*.ts",
    "!src/pure/**/*.test.ts",
    "!src/pure/**/*.d.ts",
    "!src/pure/**/index.ts",
    "!src/pure/**/__tests__/**"
  ],
  "testRunner": "vitest",
  "checkers": [],
  "vitest": {
    "configFile": "vitest.config.stryker.ts"
  },
  "concurrency": 3,
  "timeoutMS": 30000,
  "thresholds": {
    "break": null
  },
  "reporters": ["clear-text", "json"],
  "jsonReporter": {
    "fileName": "../../stryker-graph-model.json"
  },
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": "always",
  "warnings": {
    "unknownOptions": false
  }
}
