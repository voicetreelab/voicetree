{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.d.ts",
    "!src/**/index.ts",
    "!src/fixtures/**",
    "!src/fixtures.ts",
    "!src/emptyState.ts",
    "!src/rootIO.ts",
    "!tests/**"
  ],
  "testRunner": "vitest",
  "checkers": [],
  "vitest": {
    "configFile": "vitest.config.stryker.ts"
  },
  "concurrency": 3,
  "timeoutMS": 60000,
  "reporters": ["clear-text", "json"],
  "jsonReporter": {
    "fileName": "../../../stryker-graph-state.json"
  },
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": "always",
  "warnings": {
    "unknownOptions": false
  }
}
