{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "mutate": [
    "src/apply/requestFit.ts",
    "src/apply/setPan.ts",
    "src/apply/setZoom.ts"
  ],
  "testRunner": "vitest",
  "checkers": [],
  "vitest": {
    "configFile": "vitest.config.stryker.smoke.ts"
  },
  "concurrency": 3,
  "timeoutMS": 30000,
  "reporters": ["clear-text", "json"],
  "jsonReporter": {
    "fileName": "../../../stryker-graph-state-smoke.json"
  },
  "thresholds": {
    "high": 90,
    "low": 85,
    "break": 85
  },
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": "always",
  "warnings": {
    "unknownOptions": false
  }
}
