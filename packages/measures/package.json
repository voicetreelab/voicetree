{
  "name": "@vt/measures",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./vitest-reporter": "./src/_shared/writers/vitest-ci-check-reporter.ts",
    "./check-report-writer": "./src/_shared/writers/check-report-writer.ts",
    "./graph/call-graph": "./src/_shared/graph/call-graph.ts"
  },
  "scripts": {
    "test": "vitest run src/health/ src/checks/ src/_subgraph_gate/",
    "test:full": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run test:full:local",
    "test:full:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/capture-ci-checks.ts",
    "gen:workflows": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run gen:workflows:local",
    "gen:workflows:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types scripts/gen-workflows.ts",
    "sync:workflow-rulesets": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run sync:workflow-rulesets:local",
    "sync:workflow-rulesets:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types scripts/sync-workflow-rulesets.ts",
    "health:subgraph-gate": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run health:subgraph-gate:local",
    "health:subgraph-gate:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/subgraph-gate.ts",
    "orange-codebase-complexity-tests": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run orange-codebase-complexity-tests:local",
    "orange-codebase-complexity-tests:local": "vitest run src/health/complexity/hierarchical-complexity.test.ts src/health/complexity/behavioral-complexity.test.ts src/health/complexity/shape-complexity.test.ts",
    "measures": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run measures:local",
    "measures:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/record-run.ts --id=npm-health --name=\"npm run measures\" --category=Command -- pnpm --filter @vt/measures run measures:run",
    "measures:run": "node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/capture-ci-checks.ts '--tier<=2'",
    "measures:duplication": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run measures:duplication:local",
    "measures:duplication:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/record-run.ts --id=duplication --name=\"Code Duplication (jscpd)\" --category=Static --display=\"pnpm --filter @vt/measures run measures:duplication\" -- pnpm --filter @vt/measures run measures:duplication:run",
    "measures:duplication:run": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run measures:duplication:run:local",
    "measures:duplication:run:local": "cd ../.. && jscpd --config .jscpd.json backend cloud_functions packages scripts tools webapp/src",
    "measures:duplication:report": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run measures:duplication:report:local",
    "measures:duplication:report:local": "cd ../.. && jscpd --config .jscpd.json --threshold 100 backend cloud_functions packages scripts tools webapp/src",
    "measures:capture-ci": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run measures:capture-ci:local",
    "measures:capture-ci:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/capture-ci-checks.ts",
    "measures:capture-baselines": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run measures:capture-baselines:local",
    "measures:capture-baselines:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types scripts/capture-subgraph-baselines.ts",
    "measures:dashboard": "node ../../health-dashboard/server.mjs",
    "devops": "(sleep 1 && open http://localhost:8765) & node ../../health-dashboard/server.mjs",
    "test:perf:agents": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run test:perf:agents:local --",
    "test:perf:agents:local": "node --import tsx perf/agent-storm.ts",
    "perf:main-storm": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run perf:main-storm:local --",
    "perf:main-storm:local": "pnpm --filter @vt/graph-db-server run build && pnpm --filter webapp exec electron-vite build && node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/run-with-xvfb-if-needed.ts node --import tsx perf/electron-main-storm.ts",
    "test:perf:e2e-mvp": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run test:perf:e2e-mvp:local --",
    "test:perf:e2e-mvp:local": "pnpm --filter @vt/graph-db-server run build && pnpm --filter webapp exec electron-vite build && node --no-warnings=ExperimentalWarning --experimental-strip-types src/_runners/run-with-xvfb-if-needed.ts node --import tsx perf/e2e-storm-mvp/index.ts",
    "perf:diagnose:writes": "node ../../scripts/run-remote.mjs pnpm --filter @vt/measures run perf:diagnose:writes:local --",
    "perf:diagnose:writes:local": "node perf/diagnose-concurrent-writes.mjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@vt/graph-db-client": "*",
    "@vt/graph-db-server": "*",
    "@vt/graph-model": "*",
    "@vt/observability": "*",
    "@vt/perf-analysis": "*",
    "@vt/perf-fixtures": "*",
    "@vt/vt-daemon": "*",
    "@vt/vt-rpc": "*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "jsdom": "27.4.0",
    "mermaid": "11.15.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
