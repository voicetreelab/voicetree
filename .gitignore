# MCP config (worktree-local; daemon port differs per worktree)
**/.mcp.json

# Codex config (machine-local)
**/.codex/config.toml

# Agent-created nested worktree mirrors
.claude/worktrees/

# Gemini settings (machine-local)
**/.gemini/settings.json

# Wrangler
**/.wrangler/**

# Node modules — ignore both the contents AND the entry itself. The latter
# matters in git worktrees, where node_modules is a SYMLINK (a single file the
# `/**` content globs do not match), which `git add -A` would otherwise stage.
**/node_modules
**/node_modules/**

# TypeScript build state
*.tsbuildinfo

# npm pack tarballs (generated locally for publish verification)
**/*.tgz

# Web dist
**/dist-web/**

# Native modules
**/native-modules/**

# Voicetree config
**/.voicetree/**/*

# Playwright MCP artifacts
/.playwright-mcp/**/*

# Worktrees
.worktrees/**/*

# Misc
**/transcript_history.txt
**/chromadb_data/*
test_output/*
**/.claude/settings.local.json
**/.claude/settings.local.bak.json

# Vestigial root-level files that tools/agents might recreate
# (progress notes are already covered by **/*.md above)
/test.db
/opencode.json
/.obsidianignore
/.pre-commit-config.yaml

