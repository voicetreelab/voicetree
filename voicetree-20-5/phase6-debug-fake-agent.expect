#!/usr/bin/expect -f
set timeout 20
set root [lindex $argv 0]
set prompt_file [lindex $argv 1]
cd $root
set env(AGENT_PROMPT_FILE) $prompt_file
set env(AGENT_PROMPT) "WRONG_ENV_PROMPT"
set env(VOICETREE_TERMINAL_ID) "phase6-fake-debug"
set env(VOICETREE_MCP_PORT) "1"
set env(TASK_NODE_PATH) "$root/voicetree-20-5/fake-task.md"
spawn node inspect tools/vt-fake-agent/dist/index.js
expect "Break on start"
expect "debug> "
send "sb('tools/vt-fake-agent/dist/index.js', 16)\r"
expect "debug> "
send "cont\r"
expect "break in"
expect "debug> "
send "bt\r"
expect "debug> "
send "list(6)\r"
expect "debug> "
send "exec file\r"
expect "debug> "
send "exec file === env.AGENT_PROMPT_FILE\r"
expect "debug> "
send "exec env.AGENT_PROMPT\r"
expect "debug> "
send "exec process.env.AGENT_PROMPT_FILE\r"
expect "debug> "
send ".exit\r"
expect eof
