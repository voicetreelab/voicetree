{
  "permissions": {
    "allow": [
      "mcp__voicetree__create_graph",
      "mcp__voicetree__search_nodes"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/webapp/.claude/hooks/collect-changed-files.cjs\""
          },
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/webapp/.claude/hooks/file-size-check.cjs\""
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/webapp/.claude/hooks/write-search-diamond.cjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/webapp/.claude/hooks/stop-quality-check.cjs\""
          },
          {
            "type": "command",
            "command": "node --experimental-strip-types ~/brain/automation/validate-brain.ts"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "voicetree-plugins": {
      "source": {
        "source": "directory",
        "path": "./.claude/plugins"
      }
    }
  },
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "prefersReducedMotion": false
}
