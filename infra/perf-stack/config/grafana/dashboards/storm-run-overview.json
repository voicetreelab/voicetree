  "panels": [
    {
      "datasource": null,
      "description": "One-stop view of a single perf run. Sections: vt-graphd (Node, full perfProbe), vt-electron-main (CDP sampler), vt-renderer (CDP + V8 cpuprofile), vt-devbox-vm (/proc sampler), cross-cutting traces/logs/files. Pick a run_id above. Time range defaults to 7d to cover historical runs.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false },
        "content": "# Storm Run Overview\n\nOne row per producer service. Select a `run_id` above. Backends: VictoriaMetrics (metrics), Loki (logs), Tempo (traces), Pyroscope (profiles). Canonical per-run files live under `~/.voicetree/perf/$run_id/`.\n\n`vt-mcpd` is intentionally not shown — producer is not OTEL-wired in this checkout.",
        "mode": "markdown"
      },
      "pluginVersion": "13.0.1",
      "title": "Storm Run Overview",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Services that emitted any metric for the selected run.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 3 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count by (service_name) ({__name__=~\".+\", service_instance_id=\"$run_id\", service_name!=\"\"})",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Services present",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total metric series ingested for this run.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 3 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count({__name__=~\".+\", service_instance_id=\"$run_id\"})",
          "instant": false,
          "legendFormat": "metric series",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Metric series",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Total lines matching ERROR in any service for this run.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 3 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({service_instance_id=\"$run_id\"} |= \"ERROR\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log error count",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "panels": [],
      "title": "vt-graphd — Node service (perfProbeFromEnv)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "CPU seconds consumed per wall-clock second, split by user/system.",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 11,
      "options": {
