  "panels": [
    {
      "datasource": null,
      "description": "Voicetree perf-stack entry point.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "# VT Perf Runs\n\nSelect a `run_id` above, then open an overview dashboard. Backend storage is queryable here; plain files under `~/.voicetree/perf/<run_id>/` remain the canonical artifacts. See `infra/perf-stack/README.md`.",
        "mode": "markdown"
      },
      "pluginVersion": "13.0.1",
      "title": "VT Perf Runs",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Distinct run IDs seen in VictoriaMetrics over the selected time range. Open links set var-run_id on the Node Runtime overview dashboard.",
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "targetBlank": false,
              "title": "Open run overview",
              "url": "/d/node-runtime-vt/node-runtime?var-run_id=${__data.fields[\"run_id\"]}&${__url_time_range}"
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "first_seen"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "last_seen"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "label_replace(min by (service_instance_id) (min_over_time(timestamp({__name__=~\".+\", service_instance_id=~\".+\"})[$__range:1m])), \"run_stat\", \"first_seen\", \"service_instance_id\", \".+\") * 1000",
          "format": "table",
          "instant": true,
          "legendFormat": "first_seen",
          "range": false,
          "refId": "first_seen"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "label_replace(max by (service_instance_id) (max_over_time(timestamp({__name__=~\".+\", service_instance_id=~\".+\"})[$__range:1m])), \"run_stat\", \"last_seen\", \"service_instance_id\", \".+\") * 1000",
          "format": "table",
          "instant": true,
          "legendFormat": "last_seen",
          "range": false,
          "refId": "last_seen"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "label_replace(max by (service_instance_id) (max_over_time(timestamp({__name__=~\".+\", service_instance_id=~\".+\"})[$__range:1m])) - min by (service_instance_id) (min_over_time(timestamp({__name__=~\".+\", service_instance_id=~\".+\"})[$__range:1m])), \"run_stat\", \"duration\", \"service_instance_id\", \".+\")",
          "format": "table",
          "instant": true,
          "legendFormat": "duration",
          "range": false,
          "refId": "duration"
        }
      ],
      "title": "Runs table",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "valueLabel": "run_stat"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "run_stat": true,
              "Time": true
            },
            "indexByName": {}
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "service_instance_id": "run_id",
              "Value #duration": "duration",
              "Value #first_seen": "first_seen",
              "Value #last_seen": "last_seen"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": null,
      "description": "Heap snapshots intentionally stay on disk; Grafana does not ingest 100MB+ V8 object graphs.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 3,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "## Heap snapshots\n\nPath for selected run:\n\n`~/.voicetree/perf/$run_id/heap-snapshots/`\n\nLoad snapshots with Chrome DevTools -> Memory -> Load -> `<path>`. Large V8 heap snapshots remain plain files so agents and humans can inspect the same artifact without backend ingestion.",
        "mode": "markdown"
      },
      "pluginVersion": "13.0.1",
      "title": "Heap snapshots",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "count by (service_name) ({__name__=~\".+\", service_instance_id=\"$run_id\", service_name!=\"\"})",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Services present",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
