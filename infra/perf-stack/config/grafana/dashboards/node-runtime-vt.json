  "panels": [
    {
      "datasource": null,
      "description": "Node.js runtime overview for metrics emitted by perfProbeFromEnv.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "# Node Runtime\n\nMetrics shown here are emitted by `perfProbeFromEnv`: CPU time, memory usage, event-loop delay, and V8 garbage-collection observations. Select a `run_id` and optional service filter above.",
        "mode": "markdown"
      },
      "pluginVersion": "13.0.1",
      "title": "Node Runtime",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Services that emitted Node runtime memory metrics during the selected run and time range.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "count by (service_name) (max_over_time(process_memory_usage{service_instance_id=\"$run_id\", service_name=~\"$service\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{service_name}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Services present",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value": "memory_series",
              "service_name": "service"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Last observed heap_used and rss values in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "process_memory_usage{service_instance_id=\"$run_id\", service_name=~\"$service\", type=~\"heap_used|rss\"}",
          "legendFormat": "{{service_name}} {{type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Current heap + RSS",
      "type": "stat"
    },
    {
      "datasource": null,
      "description": "Heap snapshots intentionally stay on disk; Grafana does not ingest 100MB+ V8 object graphs.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "id": 4,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "## Heap snapshots\n\nPath for selected run:\n\n`~/.voicetree/perf/$run_id/heap-snapshots/`\n\nLoad snapshots with Chrome DevTools -> Memory -> Load -> `<path>`. Large V8 heap snapshots remain plain files so agents and humans can inspect the same artifact without backend ingestion.",
        "mode": "markdown"
      },
      "pluginVersion": "13.0.1",
      "title": "Heap snapshots",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "CPU seconds consumed per wall-clock second, split by user/system time.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "rate(process_cpu_time{service_instance_id=\"$run_id\", service_name=~\"$service\"}[1m])",
          "legendFormat": "{{service_name}} {{type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "CPU time rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Process memory usage emitted by Node.js process.memoryUsage().",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "process_memory_usage{service_instance_id=\"$run_id\", service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} {{type}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Memory usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "p50 and p99 event-loop delay from perf_hooks.monitorEventLoopDelay(), already exported in milliseconds.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "nodejs_eventloop_delay{service_instance_id=\"$run_id\", service_name=~\"$service\", quantile=~\"0.5|0.99\"}",
          "legendFormat": "{{service_name}} p{{quantile}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Event loop delay",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Observed V8 garbage-collection events per second.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 18
      },
      "id": 8,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "rate(runtime_gc_count{service_instance_id=\"$run_id\", service_name=~\"$service\"}[1m])",
          "legendFormat": "{{service_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "GC event rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "p99 V8 garbage-collection pause derived from runtime_gc_pause_bucket. The producer records pauses in milliseconds.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 18
      },
      "id": 9,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "13.0.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(runtime_gc_pause_bucket{service_instance_id=\"$run_id\", service_name=~\"$service\"}[1m])))",
          "legendFormat": "{{service_name}} p99",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "GC pause p99",
      "type": "timeseries"
    }
  ],
