#!/bin/bash
# Thin wrapper: runs the real pre-commit and records duration + status to the
# health dashboard. Bypass with `git commit --no-verify`.
set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"
exec node --no-warnings=ExperimentalWarning --experimental-strip-types \
  "$REPO_ROOT/packages/measures/src/_runners/record-run.ts" \
  --id=git-pre-commit \
  --name="Git pre-commit (file size)" \
  --category=Hook \
  --display=".githooks/pre-commit" \
  -- "$REPO_ROOT/.githooks/pre-commit.impl.sh" "$@"
