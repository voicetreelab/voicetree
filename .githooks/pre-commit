#!/bin/bash
# Pre-commit gate. Two hard checks, in order:
#   1. tier-0 static checks (typecheck/lint/etc) via npm run test:t0
#   2. subgraph-scoped codebase-health gate via npm run health:subgraph-gate
# Both route to the devbox automatically via the bin/npm shim when
# VT_REMOTE_HOST is set. Either failure blocks the commit.
set -e
export PATH="$(git rev-parse --show-toplevel)/bin:$PATH"

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
if printf '%s\n' "$staged_files" | grep -qE '^(packages/measures/src/checks/.*\.ts|packages/measures/scripts/gen-workflows\.ts|packages/measures/src/checks/_workflow-types\.ts)$'; then
    npm run gen:workflows
    if ! git diff --quiet -- .github/workflows/measures-budget-gate.yml; then
        echo "measures-budget-gate.yml regenerated — stage it and retry:"
        echo "  git add .github/workflows/measures-budget-gate.yml"
        exit 1
    fi
fi

npm run test:t0

# Subgraph health gate. This must run locally because it reads the local staged
# index; Onidel's replica index is refreshed from HEAD before remote execution.
# Skip cheaply if no TS/TSX is staged — those commits have nothing for the
# AST-based measures to score.
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.(ts|tsx)$'; then
    VT_REMOTE_EXEC=1 npm run health:subgraph-gate
fi
