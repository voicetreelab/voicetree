#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real location of this script
_script="${BASH_SOURCE[0]}"
while [ -L "$_script" ]; do
    _target="$(readlink "$_script")"
    case "$_target" in
        /*) _script="$_target" ;;
        *)  _script="$(dirname "$_script")/$_target" ;;
    esac
done
WEBAPP_DIR="$(cd "$(dirname "$_script")/.." && pwd)"

# Locate tsx: prefer workspace-local, fall back to monorepo-hoisted, then global.
if [ -x "$WEBAPP_DIR/node_modules/.bin/tsx" ]; then
    TSX_BIN="$WEBAPP_DIR/node_modules/.bin/tsx"
elif [ -x "$WEBAPP_DIR/../node_modules/.bin/tsx" ]; then
    TSX_BIN="$WEBAPP_DIR/../node_modules/.bin/tsx"
elif command -v tsx >/dev/null 2>&1; then
    TSX_BIN="$(command -v tsx)"
else
    echo "vt: cannot find tsx (checked $WEBAPP_DIR/node_modules/.bin/tsx, $WEBAPP_DIR/../node_modules/.bin/tsx, and PATH)" >&2
    exit 127
fi

exec "$TSX_BIN" \
    "$WEBAPP_DIR/src/shell/edge/main/cli/voicetree-cli.ts" "$@"
