{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "strictNullChecks": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./e2e-tests/*"],
      "@e2e/*": ["./e2e-tests/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
