{
  "private": true,
  "workspaces": [
    "webapp",
    "packages/measures",
    "packages/libraries/*",
    "packages/systems/*"
  ],
  "scripts": {
    "test": "node scripts/run-remote.mjs npm run test:local",
    "test:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=npm-test --name=\"npm run test\" --category=Command -- npm run test:t1",
    "test:t0": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=0'",
    "test:t1": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=1'",
    "test:t2": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=2'",
    "test:t3": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=3'",
    "test:full": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts",
    "test:vt-fake-agent": "vitest run --config tools/vt-fake-agent/vitest.config.ts",
    "test:measures": "npm --workspace @vt/measures run test",
    "orange-codebase-complexity-tests": "vitest run packages/measures/src/health/complexity/hierarchical-complexity.test.ts packages/measures/src/health/complexity/behavioral-complexity.test.ts packages/measures/src/health/complexity/shape-complexity.test.ts",
    "check": "npm run test:t1",
    "measures": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=npm-health --name=\"npm run measures\" --category=Command -- npm run measures:run",
    "measures:run": "npm run test:t2",
    "measures:duplication": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=duplication --name=\"Code Duplication (jscpd)\" --category=Static --display=\"npm run measures:duplication\" -- npm run measures:duplication:run",
    "measures:duplication:run": "jscpd --config .jscpd.json backend cloud_functions packages scripts tools webapp/src",
    "measures:duplication:report": "jscpd --config .jscpd.json --threshold 100 backend cloud_functions packages scripts tools webapp/src",
    "measures:mutation": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=mutation --name=\"Mutation Testing (Stryker)\" --category=Other --display=\"npm run measures:mutation\" --slow -- npm run measures:mutation:run",
    "measures:mutation:run": "npm --workspace @vt/graph-state run test:mutation:smoke",
    "lint": "./webapp/node_modules/.bin/eslint --no-error-on-unmatched-pattern --config webapp/eslint.config.js \"packages/libraries/graph-model/**/*.{ts,tsx}\" \"packages/libraries/graph-tools/**/*.{ts,tsx}\" \"webapp/src/**/business/**/*.{ts,tsx}\"",
    "test:fuzz": "vitest run --config vitest.config.fuzz.ts",
    "test:brain": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-strip-types --test brain/automation/*.test.ts",
    "test:e2e:tier1": "npm --workspace webapp run test:e2e:tier1",
    "test:e2e:tier2": "npm --workspace webapp run test:e2e:tier2",
    "test:e2e:tier2:browser": "npm --workspace webapp run test:e2e:tier2:browser",
    "test:e2e:tier2:electron": "node scripts/run-remote.mjs npm run test:e2e:tier2:electron:local",
    "test:e2e:tier2:electron:local": "npm --workspace webapp run test:e2e:tier2:electron",
    "measures:dashboard": "node health-dashboard/server.mjs",
    "measures:capture-ci": "node scripts/run-remote.mjs npm run measures:capture-ci:local",
    "measures:capture-ci:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts",
    "devops": "(sleep 1 && open http://localhost:8765) & node health-dashboard/server.mjs"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "jscpd": "^4.1.1",
    "jsdom": "^27.0.0",
    "knip": "^6.12.1",
    "ts-morph": "^28.0.0",
    "vitest": "^3.2.4"
  }
}
