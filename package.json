{
  "name": "voicetree-public",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "node scripts/install-vitest-shim.mjs",
    "install:devbox": "node scripts/run-remote.mjs npm install",
    "test": "node scripts/run-remote.mjs npm run test:local",
    "test:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=npm-test --name=\"npm run test\" --category=Command -- npm run test:t1",
    "check": "pnpm run test:t1",
    "test:t0": "node scripts/run-remote.mjs pnpm run test:t0:local",
    "test:t0:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=0'",
    "test:t1": "node scripts/run-remote.mjs pnpm run test:t1:local",
    "test:t1:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=1'",
    "test:t2": "node scripts/run-remote.mjs pnpm run test:t2:local",
    "test:t2:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=2'",
    "lint": "node scripts/run-remote.mjs pnpm run lint:local",
    "lint:local": "pnpm --filter webapp exec eslint --no-error-on-unmatched-pattern --config webapp/eslint.config.js \"packages/libraries/graph-model/**/*.{ts,tsx}\" \"packages/libraries/graph-tools/**/*.{ts,tsx}\" \"webapp/src/**/business/**/*.{ts,tsx}\"",
    "test:measures": "node scripts/run-remote.mjs npm run test:measures:local",
    "test:measures:local": "pnpm --filter @vt/measures run test",
    "test:e2e:tier1": "node scripts/run-remote.mjs pnpm run test:e2e:tier1:local",
    "test:e2e:tier1:local": "pnpm --filter webapp run test:e2e:tier1",
    "test:e2e:tier2": "node scripts/run-remote.mjs pnpm run test:e2e:tier2:local",
    "test:e2e:tier2:local": "pnpm --filter webapp run test:e2e:tier2",
    "test:fuzz": "node scripts/run-remote.mjs pnpm run test:fuzz:local",
    "test:fuzz:local": "vitest run --config vitest.config.fuzz.ts"
  },
  "devDependencies": {
    "@vt/measures": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@pyroscope/nodejs": "^0.4.11",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "jscpd": "^4.1.1",
    "jsdom": "^27.0.0",
    "knip": "^6.12.1",
    "ts-morph": "^28.0.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.27.7",
    "@rolldown/binding-linux-x64-gnu": "^1.0.1",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-trackpad-detect",
      "node-pty",
      "esbuild",
      "@swc/core",
      "msw"
    ]
  }
}
