{
  "name": "voicetree-public",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "node scripts/install-vitest-shim.mjs",
    "test": "node scripts/run-remote.mjs npm run test:local",
    "install:devbox": "node scripts/run-remote.mjs npm install",
    "test:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=npm-test --name=\"npm run test\" --category=Command -- npm run test:t1",
    "test:t0": "node scripts/run-remote.mjs npm run test:t0:local",
    "test:t0:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=0'",
    "health:subgraph-gate": "node scripts/run-remote.mjs npm run health:subgraph-gate:local",
    "health:subgraph-gate:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/subgraph-gate.ts",
    "gen:workflows": "node scripts/run-remote.mjs npm run gen:workflows:local",
    "gen:workflows:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/scripts/gen-workflows.ts",
    "sync:workflow-rulesets": "node scripts/run-remote.mjs npm run sync:workflow-rulesets:local",
    "sync:workflow-rulesets:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/scripts/sync-workflow-rulesets.ts",
    "test:t1": "node scripts/run-remote.mjs npm run test:t1:local",
    "test:t1:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=1'",
    "test:t2": "node scripts/run-remote.mjs npm run test:t2:local",
    "test:t2:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=2'",
    "test:t3": "node scripts/run-remote.mjs npm run test:t3:local",
    "test:t3:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=3'",
    "test:t4": "node scripts/run-remote.mjs npm run test:t4:local",
    "test:t4:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts '--tier<=4'",
    "test:full": "node scripts/run-remote.mjs npm run test:full:local",
    "test:full:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts",
    "test:vt-fake-agent": "node scripts/run-remote.mjs npm run test:vt-fake-agent:local",
    "test:vt-fake-agent:local": "vitest run --config tools/vt-fake-agent/vitest.config.ts",
    "test:measures": "node scripts/run-remote.mjs npm run test:measures:local",
    "test:measures:local": "npm --workspace @vt/measures run test",
    "orange-codebase-complexity-tests": "node scripts/run-remote.mjs npm run orange-codebase-complexity-tests:local",
    "orange-codebase-complexity-tests:local": "vitest run packages/measures/src/health/complexity/hierarchical-complexity.test.ts packages/measures/src/health/complexity/behavioral-complexity.test.ts packages/measures/src/health/complexity/shape-complexity.test.ts",
    "check": "npm run test:t1",
    "measures": "node scripts/run-remote.mjs npm run measures:local",
    "measures:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=npm-health --name=\"npm run measures\" --category=Command -- npm run measures:run",
    "measures:run": "npm run test:t2",
    "measures:duplication": "node scripts/run-remote.mjs npm run measures:duplication:local",
    "measures:duplication:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/record-run.ts --id=duplication --name=\"Code Duplication (jscpd)\" --category=Static --display=\"npm run measures:duplication\" -- npm run measures:duplication:run",
    "measures:duplication:run": "node scripts/run-remote.mjs npm run measures:duplication:run:local",
    "measures:duplication:run:local": "jscpd --config .jscpd.json backend cloud_functions packages scripts tools webapp/src",
    "measures:duplication:report": "node scripts/run-remote.mjs npm run measures:duplication:report:local",
    "measures:duplication:report:local": "jscpd --config .jscpd.json --threshold 100 backend cloud_functions packages scripts tools webapp/src",
    "lint": "node scripts/run-remote.mjs npm run lint:local",
    "lint:local": "pnpm --filter webapp exec eslint --no-error-on-unmatched-pattern --config webapp/eslint.config.js \"packages/libraries/graph-model/**/*.{ts,tsx}\" \"packages/libraries/graph-tools/**/*.{ts,tsx}\" \"webapp/src/**/business/**/*.{ts,tsx}\"",
    "test:fuzz": "node scripts/run-remote.mjs npm run test:fuzz:local",
    "test:fuzz:local": "vitest run --config vitest.config.fuzz.ts",
    "test:brain": "node scripts/run-remote.mjs npm run test:brain:local",
    "test:brain:local": "NODE_OPTIONS=--disable-warning=ExperimentalWarning node --experimental-strip-types --test brain/automation/*.test.ts",
    "test:e2e:tier1": "node scripts/run-remote.mjs npm run test:e2e:tier1:local",
    "test:e2e:tier1:local": "pnpm --filter webapp run test:e2e:tier1",
    "test:e2e:tier2": "node scripts/run-remote.mjs npm run test:e2e:tier2:local",
    "test:e2e:tier2:local": "pnpm --filter webapp run test:e2e:tier2",
    "test:e2e:tier2:browser": "node scripts/run-remote.mjs npm run test:e2e:tier2:browser:local",
    "test:e2e:tier2:browser:local": "pnpm --filter webapp run test:e2e:tier2:browser",
    "test:e2e:tier2:electron": "node scripts/run-remote.mjs npm run test:e2e:tier2:electron:local",
    "test:e2e:tier2:electron:local": "pnpm --filter webapp run test:e2e:tier2:electron",
    "test:e2e:tier2:electron-critical": "node scripts/run-remote.mjs npm run test:e2e:tier2:electron-critical:local",
    "test:e2e:tier2:electron-critical:local": "pnpm --filter webapp run test:e2e:tier2:electron-critical",
    "test:perf:agents": "node scripts/run-remote.mjs npm run test:perf:agents:local --",
    "test:perf:agents:local": "node --import tsx packages/measures/perf/agent-storm.ts",
    "electron:profile": "node scripts/run-remote.mjs npm run electron:profile:local --",
    "electron:profile:local": "node scripts/run-electron-profile.mjs",
    "perf:main-storm": "npm run electron:profile --",
    "perf:main-storm:local": "pnpm --filter @vt/graph-db-server run build && pnpm --filter webapp exec electron-vite build && node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/run-with-xvfb-if-needed.ts node --import tsx packages/measures/perf/electron-main-storm.ts",
    "test:perf:e2e-mvp": "node scripts/run-remote.mjs npm run test:perf:e2e-mvp:local --",
    "test:perf:e2e-mvp:local": "pnpm --filter @vt/graph-db-server run build && pnpm --filter webapp exec electron-vite build && node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/run-with-xvfb-if-needed.ts node --import tsx packages/measures/perf/e2e-storm-mvp/index.ts",
    "perf:diagnose:writes": "node scripts/run-remote.mjs npm run perf:diagnose:writes:local --",
    "perf:diagnose:writes:local": "node packages/measures/perf/diagnose-concurrent-writes.mjs",
    "measures:dashboard": "node health-dashboard/server.mjs",
    "perf:install": "node infra/perf-stack/scripts/install-binaries.mjs",
    "perf:up": "node infra/perf-stack/scripts/lifecycle.mjs up",
    "perf:down": "node infra/perf-stack/scripts/lifecycle.mjs down",
    "perf:check": "node infra/perf-stack/scripts/lifecycle.mjs check",
    "perf:view": "node infra/perf-stack/scripts/lifecycle.mjs view",
    "perf:scenario": "node scripts/run-perf-scenario.mjs",
    "perf:traceql": "node infra/perf-stack/scripts/traceql.mjs",
    "perf:profile-for-trace": "node infra/perf-stack/scripts/profile-for-trace.mjs",
    "perf:verify:lifecycle": "node infra/perf-stack/scripts/verify-lifecycle-persistence.mjs",
    "perf:verify:sigkill": "node infra/perf-stack/scripts/verify-sigkill-crash-resilience.mjs",
    "perf:verify": "node infra/perf-stack/scripts/verify-all.mjs",
    "measures:capture-ci": "node scripts/run-remote.mjs npm run measures:capture-ci:local",
    "measures:capture-ci:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/src/_runners/capture-ci-checks.ts",
    "measures:capture-baselines": "node scripts/run-remote.mjs npm run measures:capture-baselines:local",
    "measures:capture-baselines:local": "node --no-warnings=ExperimentalWarning --experimental-strip-types packages/measures/scripts/capture-subgraph-baselines.ts",
    "devops": "(sleep 1 && open http://localhost:8765) & node health-dashboard/server.mjs",
    "vt-resume": "node --no-warnings=ExperimentalWarning --import tsx packages/systems/agent-runtime/bin/vt-resume.ts"
  },
  "devDependencies": {
    "@vt/measures": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@pyroscope/nodejs": "^0.4.11",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "jscpd": "^4.1.1",
    "jsdom": "^27.0.0",
    "knip": "^6.12.1",
    "ts-morph": "^28.0.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.27.7",
    "@rolldown/binding-linux-x64-gnu": "^1.0.1",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-trackpad-detect",
      "node-pty",
      "esbuild",
      "@swc/core",
      "msw"
    ]
  }
}
