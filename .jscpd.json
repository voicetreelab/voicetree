{
  "minLines": 5,
  "minTokens": 50,
  "maxLines": 1000,
  "maxSize": "200kb",
  "threshold": 2,
  "reporters": ["ai", "console", "json", "sarif"],
  "output": "out/jscpd",
  "gitignore": true,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/playwright-report*/**",
    "**/test-results/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    "**/integration-tests/**",
    "**/tests/**",
    "**/fixtures/**",
    "**/test-fixtures/**",
    "**/__snapshots__/**",
    "**/*.spec.ts-snapshots/**",
    "**/*.snap",
    "**/*.map",
    "**/*.json",
    "packages/libraries/graph-tools/scripts/L3-BF-**",
    "packages/libraries/graph-tools/scripts/L3-smoke-**",
    "backend/context_retrieval/full_context.txt",
    "backend/context_retrieval/context_output.txt",
    "cloud_functions/agentic_workflows/models.py",
    "cloud_functions/agentic_workflows/tree_models.py",
    "scripts/build_and_package_*.sh",
    "scripts/build_and_package_*.ps1",
    "scripts/build_server_*.sh",
    "scripts/build_server_*.ps1"
  ]
}
